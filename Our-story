<style>
:root {
  --navy: #0f1d3a;
  --navy-soft: #1a2a4c;
  --cream: #f4ede2;
  --cream-warm: #faf3e6;
  --sand: #e8dcc8;
  --coral: #c8553d;
  --toffee: #a47551;
  --ink: #1a1a1a;
  --muted: #6b6b6b;
  --hairline: rgba(15,29,58,0.10);
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--cream);
  color: var(--ink);
  font-weight: 300;
  line-height: 1.6;
  overflow-x: hidden;
}

/* ANNOUNCEMENT BAR */
.announce {
background: var(–navy);
color: var(–cream);
text-align: center;
padding: 9px 20px;
font-size: 10px;
letter-spacing: 0.28em;
text-transform: uppercase;
font-family: ‘Inter’, sans-serif;
}

/* NAV */
nav {
background: rgba(244,237,226,0.96);
backdrop-filter: blur(12px);
padding: 10px 56px;
display: grid;
grid-template-columns: 1fr auto 1fr;
align-items: center;
border-bottom: 1px solid var(–hairline);
position: sticky;
top: 0;
z-index: 200;
}
.nav-links {
display: flex;
gap: 36px;
list-style: none;
align-items: center;
}
.nav-links a {
color: var(–navy);
text-decoration: none;
font-size: 11px;
letter-spacing: 0.2em;
text-transform: uppercase;
font-weight: 400;
transition: opacity 0.25s;
}
.nav-links a:hover { opacity: 0.5; }
.nav-links a.active { border-bottom: 1px solid var(–navy); padding-bottom: 2px; }
.logo {
text-align: center;
text-decoration: none;
display: flex;
flex-direction: column;
align-items: center;
color: var(–navy);
}
.wave-logo { width: 90px; height: 22px; margin-bottom: 2px; }
.logo-mark {
font-family: ‘Italiana’, serif;
font-size: 22px;
letter-spacing: 0.4em;
color: var(–navy);
}
.logo-sub {
font-size: 8px;
letter-spacing: 0.32em;
color: var(–muted);
text-transform: uppercase;
margin-top: 2px;
}
.nav-right {
display: flex;
gap: 22px;
align-items: center;
justify-content: flex-end;
color: var(–navy);
}
.nav-right a {
color: var(–navy);
text-decoration: none;
position: relative;
}
.cart-count {
position: absolute;
top: -7px;
right: -10px;
background: var(–coral);
color: var(–cream);
border-radius: 50%;
width: 16px;
height: 16px;
font-size: 9px;
display: flex;
align-items: center;
justify-content: center;
font-weight: 400;
}

/* PAGE HEADER */
.page-header {
text-align: center;
padding: 88px 20px 56px;
background: var(–cream);
}
.eyebrow {
font-size: 10px;
letter-spacing: 0.34em;
text-transform: uppercase;
color: var(–coral);
margin-bottom: 22px;
font-weight: 400;
}
.page-header h1 {
font-family: ‘Italiana’, serif;
font-size: clamp(54px, 8vw, 96px);
font-weight: 300;
color: var(–navy);
letter-spacing: 0.02em;
line-height: 1.05;
}
.header-divider {
width: 60px;
height: 1px;
background: var(–coral);
margin: 32px auto 0;
}

/* HERO IMAGE */
.story-hero {
width: 100%;
height: 70vh;
min-height: 480px;
background-image: url(‘https://images.unsplash.com/photo-1502136969935-8d8eef54d77b?w=1800&q=80’);
background-size: cover;
background-position: center;
position: relative;
}
.story-hero::after {
content: ‘’;
position: absolute;
inset: 0;
background: linear-gradient(to bottom, transparent 60%, var(–cream) 100%);
}

/* CHAPTERS */
.chapter {
max-width: 1180px;
margin: 0 auto;
padding: 96px 56px;
display: grid;
grid-template-columns: 1fr 1fr;
gap: 80px;
align-items: center;
}
.chapter.reverse .chapter-img { order: 2; }
.chapter-img {
width: 100%;
aspect-ratio: 4/5;
background-size: cover;
background-position: center;
}
.chapter-text .ch-eyebrow {
font-size: 10px;
letter-spacing: 0.34em;
text-transform: uppercase;
color: var(–coral);
margin-bottom: 18px;
font-weight: 400;
}
.chapter-text h2 {
font-family: ‘Cormorant Garamond’, serif;
font-style: italic;
font-size: clamp(36px, 5vw, 52px);
font-weight: 300;
color: var(–navy);
line-height: 1.1;
margin-bottom: 28px;
}
.chapter-text p {
font-size: 15px;
color: var(–ink);
margin-bottom: 18px;
max-width: 480px;
}

/* QUOTE BAND */
.quote-band {
background: var(–navy);
color: var(–cream);
padding: 100px 56px;
text-align: center;
}
.quote-band blockquote {
font-family: ‘Cormorant Garamond’, serif;
font-style: italic;
font-size: clamp(28px, 3.8vw, 42px);
font-weight: 300;
max-width: 840px;
margin: 0 auto 30px;
line-height: 1.35;
}
.quote-band cite {
font-style: normal;
font-size: 10px;
letter-spacing: 0.3em;
text-transform: uppercase;
color: rgba(244,237,226,0.7);
}

/* VALUES */
.values {
max-width: 1180px;
margin: 0 auto;
padding: 96px 56px;
text-align: center;
}
.values h2 {
font-family: ‘Italiana’, serif;
font-size: clamp(34px, 4.5vw, 48px);
color: var(–navy);
margin-bottom: 14px;
}
.values .subtitle {
font-size: 13px;
color: var(–muted);
margin-bottom: 64px;
max-width: 520px;
margin-left: auto;
margin-right: auto;
}
.value-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 56px;
text-align: left;
}
.value-item {
border-top: 1px solid var(–hairline);
padding-top: 24px;
}
.value-num {
font-family: ‘Italiana’, serif;
font-size: 14px;
color: var(–coral);
letter-spacing: 0.2em;
margin-bottom: 16px;
display: block;
}
.value-item h3 {
font-family: ‘Cormorant Garamond’, serif;
font-style: italic;
font-size: 24px;
color: var(–navy);
font-weight: 400;
margin-bottom: 12px;
}
.value-item p {
font-size: 14px;
color: var(–muted);
line-height: 1.7;
}

/* CTA */
.cta {
text-align: center;
padding: 100px 56px 120px;
background: var(–cream-warm);
}
.cta h2 {
font-family: ‘Italiana’, serif;
font-size: clamp(36px, 5vw, 52px);
color: var(–navy);
margin-bottom: 20px;
}
.cta p {
color: var(–muted);
font-size: 14px;
margin-bottom: 36px;
max-width: 460px;
margin-left: auto;
margin-right: auto;
}
.cta-btn {
display: inline-block;
padding: 16px 44px;
background: var(–navy);
color: var(–cream);
text-decoration: none;
font-size: 11px;
letter-spacing: 0.28em;
text-transform: uppercase;
border: 1px solid var(–navy);
transition: all 0.3s;
}
.cta-btn:hover {
background: transparent;
color: var(–navy);
}

/* FOOTER */
footer {
background: var(–navy);
color: var(–cream);
padding: 80px 56px 32px;
}
.footer-grid {
max-width: 1280px;
margin: 0 auto;
display: grid;
grid-template-columns: 1.4fr 1fr 1fr 1fr;
gap: 48px;
padding-bottom: 56px;
border-bottom: 1px solid rgba(244,237,226,0.12);
}
.footer-brand .f-logo {
font-family: ‘Italiana’, serif;
font-size: 26px;
letter-spacing: 0.4em;
display: block;
margin-bottom: 18px;
}
.footer-brand p {
font-size: 13px;
color: rgba(244,237,226,0.65);
max-width: 280px;
}
.footer-col h4 {
font-family: ‘Inter’, sans-serif;
font-size: 11px;
letter-spacing: 0.28em;
text-transform: uppercase;
font-weight: 400;
margin-bottom: 22px;
color: var(–cream);
}
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: 10px; }
.footer-col ul li a {
color: rgba(244,237,226,0.65);
text-decoration: none;
font-size: 13px;
transition: color 0.2s;
}
.footer-col ul li a:hover { color: var(–cream); }
.footer-bottom {
text-align: center;
font-size: 10px;
color: rgba(244,237,226,0.4);
letter-spacing: 0.18em;
text-transform: uppercase;
padding-top: 32px;
}

@media (max-width: 900px) {
nav { padding: 10px 20px; }
.nav-links { display: none; }
.chapter { grid-template-columns: 1fr; gap: 40px; padding: 72px 24px; }
.chapter.reverse .chapter-img { order: 0; }
.value-grid { grid-template-columns: 1fr; gap: 36px; }
.footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
footer { padding: 56px 24px 28px; }
}
@media (max-width: 520px) {
.footer-grid { grid-template-columns: 1fr; }
}
</style>

